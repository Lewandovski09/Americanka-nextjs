# ============================================
# AMERICANKA — Environment Variables
# ============================================
# On Vercel, paste these into Project Settings -> Environment Variables.
# Locally, copy this file to .env.local for testing.

# ---- Supabase ----
# Find these in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# ---- Telegram Bot ----
# Get this from @BotFather on Telegram (see README for steps)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ---- Gmail (for email verification codes) ----
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
